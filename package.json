{
  "name": "autoai",
  "version": "0.1.0",
  "description": "Connect to any AI — free, without API keys",
  "private": true,
  "_scripts_doc": {
    "feedback:live:all": "T1–T3 pipeline pass; T4/T5 use pass.strict MVP acceptance (pytest + modules + traceability). Report shows strict delivery: X/Y.",
    "feedback:live:t4": "Strict delivery tier — fails if tests red or MVP layout incomplete (ADR-0004).",
    "feedback:live:t6": "确定性多切片平台及格线（CRUD+状态机+数据管道）。与量化语义解耦的 strict 靶子；:batch 连跑 3 次取成功率（决策记录 D2/D3）。"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "build:core": "tsc -b packages/stagent-core",
    "predev": "npm run build:core",
    "prebuild": "npm run build:core",
    "pretypecheck": "npm run build:core",
    "pretest": "npm run build:core",
    "dev": "electron-vite dev",
    "dev:playwright": "AUTOAI_AUTOMATION_MODE=playwright electron-vite dev",
    "dev:playwright:chatgpt": "AUTOAI_PLAYWRIGHT_HOSTS=chatgpt.com electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "preview:playwright": "AUTOAI_AUTOMATION_MODE=playwright electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:headless": "npm run build:core && node --test scripts/headless/lib/*.test.mjs",
    "test:e2e": "npm run build && playwright test",
    "feedback": "npm run build:core && node scripts/headless/run.mjs",
    "feedback:quick": "node scripts/headless/run.mjs",
    "feedback:live": "node scripts/headless/run.mjs --live --scenario execute --live-tier 1 --keep",
    "feedback:live:all": "node scripts/headless/run.mjs --live --scenario execute --live-tier all --keep",
    "feedback:live:t4:resume": "node scripts/headless/run.mjs --live --scenario execute --live-tier 4 --keep --resume",
    "feedback:live:t2": "node scripts/headless/run.mjs --live --scenario execute --live-tier 2 --keep",
    "feedback:live:t3": "node scripts/headless/run.mjs --live --scenario execute --live-tier 3 --keep",
    "feedback:live:t4": "node scripts/headless/run.mjs --live --scenario execute --live-tier 4 --keep",
    "feedback:live:t4:batch": "node scripts/headless/run.mjs --live --scenario execute --live-tier 4 --keep --repeat 5",
    "feedback:live:t5": "node scripts/headless/run.mjs --live --scenario execute --live-tier 5 --keep",
    "feedback:live:t6": "node scripts/headless/run.mjs --live --scenario execute --live-tier 6 --keep",
    "feedback:live:t6:batch": "node scripts/headless/run.mjs --live --scenario execute --live-tier 6 --keep --repeat 3",
    "feedback:unit": "npm run build:core && node scripts/headless/run.mjs --with-unit",
    "feedback:charter-suggest": "npm run build:core && node scripts/headless/run.mjs --scenario charter-suggest --keep",
    "feedback:charter-auto": "npm run build:core && node scripts/headless/run.mjs --scenario charter-auto --keep",
    "docs:check": "node scripts/check-docs-links.mjs",
    "regression:loop": "node scripts/run-regression-loop.js",
    "extract:failure-snapshot": "node scripts/extract-failure-snapshot.js",
    "extract:engine-failure": "node scripts/extract-engine-failure.mjs",
    "log:draft": "node scripts/generate-run-log-entry.mjs",
    "log:manifest": "node scripts/generate-run-log-entry.mjs --init-manifest",
    "adapter:gates": "node scripts/check-adapter-gates.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@stagent/core": "file:./packages/stagent-core",
    "electron-log": "^5.4.3",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.378.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.5"
  }
}
